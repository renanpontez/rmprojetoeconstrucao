#!/usr/bin/env bash
#
# Run before every `git push`. Aborts if typecheck or the full Next.js build
# fail. Catches the things `tsc --noEmit` alone cannot: build-time SSG errors,
# Next 16 cache-life signature changes, missing client/server boundaries.
#
# Skip with: git push --no-verify  (don't make this a habit)
#
set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Allow skipping the heavy build for hotfix/no-code branches via env var.
if [ "${SKIP_PREPUSH_BUILD:-0}" = "1" ]; then
  echo "→ [pre-push] SKIP_PREPUSH_BUILD=1 set — skipping build"
  exit 0
fi

# Short-circuit on delete-only pushes (e.g. `git push origin --delete branch`).
# Git pipes one `<local-ref> <local-sha> <remote-ref> <remote-sha>` line per
# ref being pushed; for deletes, local-sha is all zeros.
ZERO_SHA="0000000000000000000000000000000000000000"
SAW_REF=0
ALL_DELETES=1
while read -r local_ref local_sha remote_ref remote_sha; do
  SAW_REF=1
  if [ "$local_sha" != "$ZERO_SHA" ]; then
    ALL_DELETES=0
  fi
done
if [ "$SAW_REF" = "1" ] && [ "$ALL_DELETES" = "1" ]; then
  echo "→ [pre-push] delete-only push — skipping build"
  exit 0
fi

echo "→ [pre-push] TypeScript check (apps/web + apps/studio)"
npm run typecheck

echo "→ [pre-push] Next.js build (apps/web — same command Vercel runs)"
npm run build

echo "✓ [pre-push] passed"
