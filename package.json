{
  "name": "rm-projetos-construcao",
  "version": "0.2.3",
  "private": true,
  "description": "RM Projetos & Construção - Website Builder Multi-Agent System",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=web",
    "dev:web": "npm run dev --workspace=web",
    "dev:studio": "npm run dev --workspace=studio",
    "build": "npm run build --workspace=web",
    "build:all": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "seed": "npm run seed --workspace=web",
    "seed:dry": "npm run seed:dry --workspace=web",
    "seed:force": "npm run seed:force --workspace=web",
    "inspect:sanity": "npm run inspect:sanity --workspace=web",
    "studio:deploy": "npm run deploy --workspace=studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
