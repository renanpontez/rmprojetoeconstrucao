{
  "meta": {
    "project_name": "Website Builder Multi-Agent System",
    "version": "0.2.3",
    "single_source_of_truth": true
  },
  "status": {
    "current_phase": "build",
    "gate": "OPEN",
    "ready_to_advance": true,
    "blocking_reasons": []
