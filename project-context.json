        "cms": {
          "provider": "Sanity v3",
          "studio_location": "apps/studio",
          "datasets": ["development", "production"]
        },
        "deploy": {
          "hosting": "Vercel",
          "cms_hosting": "Sanity hosted Studio (recommended)",
          "env_management": "Vercel environment variables"
        },
        "analytics": {
          "default": "GTM + GA4",
          "optional": ["Vercel Analytics", "Vercel Speed Insights"]
        }
