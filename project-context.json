          "src/lib/sanity/queries.ts",
          "src/lib/sanity/image.ts",
          "src/lib/analytics/track.ts",
          "src/lib/analytics/events.ts",
          "src/lib/seo/jsonld.ts",
          "src/lib/seo/metadata.ts",
          "src/styles/globals.css",
