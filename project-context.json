      "data_layer": {
        "content_source": "Sanity (siteSettings + landingPage)",
        "fetching": {
          "mode": "server components fetch on request",
          "cache": "Next.js fetch caching",
          "revalidate_seconds": 3600
        },
        "queries": [
          "getSiteSettings",
          "getLandingPage",
          "getServices",
          "getPortfolioItems"
        ],
        "fallback_policy": {
          "dev": "Allow fallback seeded content if CMS empty",
          "prod": "Require published siteSettings + landingPage; show safe minimal UI if missing"
        }
      },
      "cms": {
        "schemas": {
          "documents": [
            {
              "name": "siteSettings",
              "singleton": true,
              "fields": [
                "siteName",
                "logo",
                "contacts: { whatsapp, email }",
                "serviceArea: { city, state }",
                "legal: { professionalTitle, creaNumber, creaUF, cnpj, legalName }",
                "primaryCTA: cta",
                "seoDefaults: { titleTemplate, defaultDescription, ogImage }"
              ],
              "seed_values": {
                "siteName": "RM Projetos & Construção",
                "contacts.whatsapp": "+55 85 99988-0988",
                "contacts.email": "dr.robertofm@gmail.com",
                "serviceArea.city": "Fortaleza",
                "serviceArea.state": "CE",
                "legal.professionalTitle": "Engenheiro Civil",
                "legal.creaUF": "CE",
                "legal.creaNumber": "123456",
                "legal.cnpj": "1234567890001-12"
              }
            },
            {
              "name": "landingPage",
              "singleton": true,
              "fields": [
                "hero: { headline, subheadline, image, primaryCTAOverride? }",
                "about: { title, body[], founderName, founderRole, portrait, trustItems[] }",
                "services: [reference(service)]",
                "portfolio: [reference(portfolioItem)]",
                "ctaBlocks: [ctaBlock]"
              ]
            },
            { "name": "service", "fields": ["title", "description", "icon", "order"] },
            {
              "name": "portfolioItem",
              "fields": ["title", "summary", "type", "location", "year", "images[]", "highlights[]"]
            }
          ],
          "objects": [
            { "name": "cta", "fields": ["label", "type", "href", "eventName"] },
            { "name": "ctaBlock", "fields": ["headline", "supportingText", "cta", "secondaryCta?"] }
          ]
        }
