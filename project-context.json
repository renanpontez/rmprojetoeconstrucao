        "decision": "Keep /politica-de-privacidade as a simple placeholder page for now (no form data collection), can be expanded later."
      },
      "tailwind_and_shadcn": {
        "decision": "Use Tailwind config overrides (theme.extend) instead of complex CSS variables system; keep globals.css minimal.",
        "tailwind_config_overrides": {
          "colors": "Map experience tokens to Tailwind semantic colors (primary/secondary/accent/surface/border/text).",
          "radius": "Match sm/md/lg",
          "shadows": "Add shadow-sm/shadow-md equivalents to match tokens",
          "typography": "Use Inter via next/font and Tailwind fontFamily",
          "spacing": "Rely on Tailwind scale; use custom only if necessary"
        },
        "shadcn_usage": {
          "base_components": [
            "button",
            "card",
            "badge",
            "input",
            "textarea",
            "dialog",
            "sheet",
            "separator"
          ],
          "wrappers": [
            "Container",
            "SectionHeading",
            "CTAButton (bind analytics + WhatsApp href)",
            "NavLink (anchor + focus-visible)"
          ]
        }
      },
