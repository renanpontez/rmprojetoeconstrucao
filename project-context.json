        "business": {
          "brand_name": "RM Projetos & Construção",
          "description": "Empresa cearense gerida pelo engenheiro civil Roberto Martins.",
          "cnpj": "1234567890001-12",
          "email": "dr.robertofm@gmail.com",
          "whatsapp": "+55 85 99988-0988",
          "crea": {
            "uf": "CE",
            "number": "123456",
