# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity — required for production
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity tokens (server-only; never expose to client)
# Editor token used by the seed script + draft reads. Generate at sanity.io/manage > API > Tokens.
SANITY_WRITE_TOKEN=
# Optional viewer token. Falls back to SANITY_WRITE_TOKEN when blank.
SANITY_READ_TOKEN=

# Webhook secret paired with the Sanity dashboard webhook.
# Generate a long random string (e.g. `openssl rand -hex 32`).
SANITY_REVALIDATE_SECRET=

# Analytics (optional)
NEXT_PUBLIC_GTM_ID=
